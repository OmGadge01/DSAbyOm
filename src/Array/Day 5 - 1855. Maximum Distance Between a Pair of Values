class Solution {
    public int maxDistance(int[] nums1, int[] nums2) {
        int maxdist = 0;
        int i =0;
        int j =0;
        int len1 = nums1.length;
        int len2 = nums2.length; 
        while(i < len1 && j < len2){
            if(nums1[i] <= nums2[j]){
                maxdist = Math.max(maxdist , j -i);
                j++;
            }
            else{
                i++;
                j++;
            }
        }
        return maxdist;
    }

}
